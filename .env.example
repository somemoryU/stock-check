# Optional config override file path
STOCK_CHECK_CONFIG=

# Optional scoring config override file path
STOCK_CHECK_SCORING_CONFIG=

# Optional single-key overrides
STOCK_CHECK_RUNS_DIR=runs
STOCK_CHECK_TIMEOUT_SECONDS=30
STOCK_CHECK_USER_AGENT=Mozilla/5.0
STOCK_CHECK_PDFTOTEXT_PATH=/opt/homebrew/bin/pdftotext
STOCK_CHECK_SCRAPLING_PYTHON=/path/to/scrapling/venv/bin/python
STOCK_CHECK_SCORING_ENABLED=true
